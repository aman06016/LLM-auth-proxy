{
  "server": {
    "host": "127.0.0.1",
    "port": 4318
  },
  "defaultBackend": "codex",
  "backends": {
    "codex": {
      "type": "codex-oauth",
      "authFile": "~/.codex/auth.json",
      "baseUrl": "https://chatgpt.com/backend-api",
      "responsesPath": "/codex/responses"
    },
    "openai": {
      "type": "api-key",
      "baseUrl": "https://api.openai.com/v1",
      "apiKeyEnv": "OPENAI_API_KEY"
    }
  }
}
